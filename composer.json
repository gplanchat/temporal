{
    "name": "kiboko/temporal",
    "description": "Client Temporal PHP framework-agnostic (transport HTTP PSR-18, gRPC, workflows async)",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/gplanchat/temporal",
    "support": {
        "source": "https://github.com/gplanchat/temporal",
        "issues": "https://github.com/gplanchat/temporal/issues"
    },
    "version": "0.1.0",
    "require": {
        "php": "^8.1",
        "google/protobuf": "^4.31",
        "grpc/grpc": "^1.57",
        "roadrunner-php/roadrunner-api-dto": "^1.14",
        "nyholm/psr7": "^1.8",
        "psr/clock": "^1.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1|^2.0",
        "revolt/event-loop": "^1.0",
        "symfony/http-client": "^6.4 || ^7.0",
        "symfony/uid": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "psr/container": "^2.0"
    },
    "suggest": {
        "psr/container": "Pour ActivityRegistry / handlers d’activité injectés",
        "phpunit/phpunit": "Pour les classes Kiboko\\Temporal\\Testing\\*"
    },
    "autoload": {
        "psr-4": {
            "Kiboko\\Temporal\\": ""
        },
        "files": [
            "Async/functions.php"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
