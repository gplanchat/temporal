{
    "name": "kiboko/temporal",
    "description": "Client Temporal PHP framework-agnostic (transport HTTP PSR-18, extension gRPC côté applications)",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/gplanchat/temporal",
    "support": {
        "source": "https://github.com/gplanchat/temporal",
        "issues": "https://github.com/gplanchat/temporal/issues"
    },
    "version": "0.1.0",
    "require": {
        "php": "^8.1",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1|^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Kiboko\\Temporal\\": ""
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
